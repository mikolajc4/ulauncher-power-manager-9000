{
  "manifest_version": "2",
  "required_api_version": "2",
  "api_version": "1",
  "name": "Power Manager 9000",
  "description": "Lock, Suspend, Naptime, Logout, Shut Down and Restart from Ulauncher. Fork of AlexNabokikh/ulauncher-power-manager.",
  "developer_name": "mikolajc4",
  "icon": "icon.svg",
  "preferences": [
    {
      "id": "lock-screen",
      "type": "keyword",
      "name": "Lock Screen",
      "default_value": "Lock Screen",
      "description": "Lock your screen"
    },
    {
      "id": "restart",
      "type": "keyword",
      "name": "Reboot / Restart",
      "default_value": "Reboot / Restart",
      "description": "Restart the system"
    },
    {
      "id": "suspend",
      "type": "keyword",
      "name": "Suspend / Sleep",
      "default_value": "Suspend / Sleep",
      "description": "Lock screen and suspend the system"
    },
    {
      "id": "shutdown",
      "type": "keyword",
      "name": "Shut Down / Power Off",
      "default_value": "Shut Down / Power Off",
      "description": "Shut down system"
    },
    {
      "id": "naptime",
      "type": "keyword",
      "name": "Naptime",
      "default_value": "Naptime",
      "description": "Suspend without locking the screen"
    },
    {
      "id": "logout",
      "type": "keyword",
      "name": "Logout",
      "default_value": "Logout",
      "description": "Log out of the current session"
    },
    {
      "id": "safe-logout",
      "type": "keyword",
      "name": "Safe Logout",
      "default_value": "Safe Logout",
      "description": "Cleanly log out of the current session"
    }
  ]
}
